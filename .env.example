# ============================================
# Danse Macabre — Environment Configuration
# ============================================
# Copy to .env and adjust for your environment.
# Dev works out of the box. For prod: change APP_ENV, APP_KEY, APP_DOMAIN, DB_PASSWORD.

# --- Core ---
APP_ENV=local
APP_KEY=
APP_DOMAIN=localhost
APP_DEBUG=true

# --- Database ---
DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=danse_macabre
DB_USERNAME=postgres
DB_PASSWORD=postgres

# --- Dev only (Docker host forwarding, ignored in prod) ---
FORWARD_DB_PORT=5432
APP_PORT=8000
FRONTEND_PORT=3000
